<%
  frac = @total > 0 ? @done.to_f / @total : 0
  pct = @total > 0 ? (frac * 100).round : nil
  deg = (frac * 360).round
  ring_bg = @total > 0 ? "conic-gradient(#2D2925 #{deg}deg, #DDD5C9 #{deg}deg)" : "#EBE4DA"
  progress_label = @total == 0 ? "Nothing planned yet" : "#{@done} of #{@total} done"
  p_count = @priorities.count
  chip = "#{p_count} / 5"
  hint = case p_count
         when 0 then "Aim for about five a day."
         when 1..4 then "A few more to reach five — or stop here."
         when 5 then "Five — a full day."
         else "A big day. Trim if you can."
         end
%>

<% if @plan_item.kind == "gratitude" %>
  <%= turbo_stream.append "gratitude-list" do %>
    <%= render partial: "plan_items/gratitude_item", locals: { gratitude_item: @plan_item } %>
  <% end %>
<% else %>
  <%= turbo_stream.append "#{@plan_item.kind == 'priority' ? 'priorities' : 'extras'}-list" do %>
    <%= render partial: "plan_items/plan_item", locals: { plan_item: @plan_item } %>
  <% end %>
<% end %>

<%= turbo_stream.update "plan-header" do %>
  <div style="flex:none; width:54px; height:54px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:<%= ring_bg %>;">
    <div style="width:42px; height:42px; border-radius:50%; background:#FBF8F4; display:flex; align-items:center; justify-content:center;">
      <span style="font-size:13px; font-weight:800; color:#2D2925;"><%= pct ? "#{pct}%" : "–" %></span>
    </div>
  </div>
  <div>
    <div style="font-size:12px; font-weight:800; letter-spacing:0.16em; color:#B0A698;"><%= @date == Date.current ? "TODAY" : @date.strftime("%A").upcase %></div>
    <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.05;"><%= @date.strftime("%b %-d") %></div>
    <div style="font-size:14px; font-weight:600; color:#998F82; margin-top:2px;"><%= progress_label %></div>
  </div>
<% end %>

<%= turbo_stream.update "priority-chip" do %>
  <%= chip %>
<% end %>

<%= turbo_stream.update "priority-hint" do %>
  <%= hint %>
<% end %>
