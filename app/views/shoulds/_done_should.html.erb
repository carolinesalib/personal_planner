<%= turbo_frame_tag should do %>
  <div class="should-item" id="<%= dom_id(should, :done) %>">
    <%= button_to restore_should_path(should), method: :patch, class: "should-ring should-ring--done", form: { data: { turbo_frame: "_top" } } do %>
      ✓
    <% end %>

    <span class="should-text should-text--done"><%= should.title %></span>

    <button class="should-remove"
            data-action="click->delete-confirm#show"
            data-delete-confirm-title-param="<%= should.title %>"
            data-delete-confirm-url-param="<%= should_path(should) %>">×</button>
  </div>
<% end %>
