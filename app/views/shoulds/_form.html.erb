<%= form_with model: Should.new, url: shoulds_path, class: "should-add-row", data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
  <span class="should-add-ring"></span>
  <%= f.text_field :title, placeholder: "Add a should…", class: "should-add-input", autocomplete: "off", data: { reset_form_target: "input" } %>
  <%= f.submit "Add", class: "should-add-btn" %>
<% end %>
