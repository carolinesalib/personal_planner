<div>
  <%= link_to shoulds_path, style: "text-decoration:none; font-size:15px; font-weight:700; color:#9A9183; display:flex; align-items:center; gap:7px; padding:6px 0;" do %>
    <span style="font-size:17px;">←</span> Back
  <% end %>

  <div style="font-size:32px; font-weight:900; color:#2D2925; line-height:1; margin-top:12px;">Completed</div>
  <div style="font-size:15px; font-weight:600; color:#998F82; margin-top:8px;">
    <%= pluralize(@shoulds.count, "thing") %> checked off. Nice.
  </div>

  <div id="done-list" style="margin-top:20px; display:flex; flex-direction:column;">
    <% if @shoulds.any? %>
      <%= render partial: "done_should", collection: @shoulds, as: :should %>
    <% else %>
      <div id="done-empty" style="padding:44px 0; font-size:14px; font-weight:600; color:#A39A8D;">Nothing checked off yet.</div>
    <% end %>
  </div>
</div>
