<%= turbo_stream.remove @should %>
<%= turbo_stream.update "shoulds-badge" do %>
  <%= pluralize(current_user.shoulds.active.count, "item") %>
<% end %>
<%= turbo_stream.update "done-count" do %>
  <%= current_user.shoulds.done.count %> completed
<% end %>
<%= turbo_stream.update "done-subtitle" do %>
  <%= pluralize(current_user.shoulds.done.count, "thing") %> checked off. Nice.
<% end %>
