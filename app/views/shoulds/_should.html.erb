<%= turbo_frame_tag should do %>
  <div class="should-item" id="<%= dom_id(should) %>">
    <%= button_to complete_should_path(should), method: :patch, class: "should-ring", form: { data: { turbo_frame: "_top" } } do %>
      ✓
    <% end %>

    <span class="should-text"
          data-controller="inline-edit"
          data-inline-edit-url-value="<%= should_path(should) %>"
          data-action="click->inline-edit#edit">
      <%= should.title %>
    </span>

    <button class="should-remove"
            data-action="click->delete-confirm#show"
            data-delete-confirm-title-param="<%= should.title %>"
            data-delete-confirm-url-param="<%= should_path(should) %>">×</button>
  </div>
<% end %>
