<div>
  <div style="display:flex; align-items:baseline; justify-content:space-between; margin-top:6px;">
    <div style="font-size:32px; font-weight:900; color:#2D2925; line-height:1;">Shoulds</div>
    <div id="shoulds-badge" style="font-size:14px; font-weight:700; color:#B0A698;">
      <%= pluralize(@shoulds.count, "item") %>
    </div>
  </div>
  <div style="font-size:15px; font-weight:600; color:#998F82; margin-top:8px;">Dump it here, get to it later.</div>

  <div style="margin-top:22px;">
    <%= render "form" %>
  </div>

  <div id="shoulds-list" style="display:flex; flex-direction:column;">
    <% if @shoulds.any? %>
      <%= render partial: "should", collection: @shoulds %>
    <% else %>
      <div id="empty-state" style="padding:48px 0 30px; display:flex; flex-direction:column; gap:10px;">
        <div style="font-size:17px; font-weight:800; color:#2D2925;">Nothing here.</div>
        <div style="font-size:14px; font-weight:600; color:#A39A8D; max-width:230px; line-height:1.45;">The list is empty. That's the goal. Add the next one the moment it pops into your head.</div>
      </div>
    <% end %>
  </div>

  <div style="margin-top:26px; padding-top:18px; border-top:1px solid #ECE5DB;">
    <%= link_to completed_shoulds_path, style: "text-decoration:none; font-size:15px; font-weight:700; color:#9A9183; display:flex; align-items:center; gap:7px; padding:2px 0;" do %>
      <span id="done-count"><%= @done_count %> completed</span> <span style="font-size:16px;">→</span>
    <% end %>
  </div>
</div>
