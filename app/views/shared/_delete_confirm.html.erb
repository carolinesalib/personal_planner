<div data-delete-confirm-target="modal"
     data-action="click->delete-confirm#backdropClick"
     style="display:none; position:absolute; inset:0; z-index:60; align-items:flex-end; justify-content:center; background:rgba(26,23,20,0.40); padding:16px;">
  <div style="width:100%; background:#FBF8F4; border-radius:28px; padding:26px 24px 22px; box-shadow:0 24px 60px rgba(26,23,20,0.34);">
    <div style="width:46px; height:46px; border-radius:14px; background:#F6E4DE; display:flex; align-items:center; justify-content:center;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#B5503A" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4,7 20,7"></polyline><path d="M9 7V5.5A1.5 1.5 0 0 1 10.5 4h3A1.5 1.5 0 0 1 15 5.5V7"></path><path d="M6 7l1 12.5A1.5 1.5 0 0 0 8.5 21h7a1.5 1.5 0 0 0 1.5-1.5L18 7"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
    </div>
    <div style="font-size:21px; font-weight:900; color:#2D2925; margin-top:16px;">Delete this?</div>
    <div style="font-size:15px; font-weight:600; color:#8A8076; margin-top:8px; line-height:1.5;">
      "<span style="color:#2D2925; font-weight:700;" data-delete-confirm-target="label"></span>" will be removed for good — this can't be undone.
    </div>
    <div style="display:flex; gap:12px; margin-top:24px;">
      <button data-action="click->delete-confirm#cancel" style="flex:1; height:52px; border-radius:15px; border:none; background:#EFE9E1; cursor:pointer; font-size:16px; font-weight:800; color:#2D2925; font-family:inherit;">Keep</button>
      <%= form_tag "", method: :delete, data: { turbo_frame: "_top", delete_confirm_target: "form" }, style: "flex:1; display:flex;" do %>
        <button type="submit" style="flex:1; height:52px; border-radius:15px; border:none; background:#B5503A; cursor:pointer; font-size:16px; font-weight:800; color:#FBF8F4; font-family:inherit;">Delete</button>
      <% end %>
    </div>
  </div>
</div>
