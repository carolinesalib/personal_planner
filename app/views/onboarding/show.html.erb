<%= form_with url: onboarding_complete_path, method: :post,
      data: { controller: "onboarding", onboarding_total_value: 5, onboarding_current_value: @step },
      html: { style: "flex:1; display:flex; flex-direction:column; min-height:0;" } do |f| %>
  <input type="hidden" name="gratitude_enabled" value="1">

  <%# Dots + Skip %>
  <div style="display:flex; align-items:center; justify-content:space-between; padding:20px 24px 0;">
    <div style="display:flex; gap:6px; align-items:center;">
      <% 5.times do |i| %>
        <div data-onboarding-target="dot"
             style="width:<%= i + 1 == @step ? '20px' : '7px' %>; height:7px; border-radius:99px; background:<%= i + 1 == @step ? '#2D2925' : '#C7BEB1' %>; transition:all 0.2s;"></div>
      <% end %>
    </div>
    <button type="submit" data-action="onboarding#skip"
            style="font-size:14px; font-weight:700; color:#998F82; background:none; border:none; cursor:pointer; font-family:inherit; padding:0;">Skip</button>
  </div>

  <%# Steps %>
  <div style="flex:1; display:flex; flex-direction:column; min-height:0;">

    <%# Step 1: Welcome %>
    <div data-onboarding-target="step"
         style="display:<%= @step == 1 ? 'flex' : 'none' %>; flex:1; flex-direction:column; align-items:center; justify-content:center; padding:32px 32px 0; text-align:center;">
      <div style="width:120px; height:120px; border-radius:50%; background:#EDE8E1; display:flex; align-items:center; justify-content:center; margin-bottom:32px;">
        <img src="/icon.png" alt="" style="width:80px; height:80px; border-radius:24px; box-shadow:0 8px 20px rgba(45,41,37,0.18);">
      </div>
      <div style="font-size:12px; font-weight:800; letter-spacing:0.1em; color:#C2956F; text-transform:uppercase; margin-bottom:10px;">Welcome</div>
      <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.15; margin-bottom:14px;">A lighter way to live</div>
      <div style="font-size:15px; font-weight:600; color:#998F82; line-height:1.6; max-width:280px;">Empty your head. Focus on what matters today. Let everything else wait, safely held, until its time comes.</div>
    </div>

    <%# Step 2: Shoulds %>
    <div data-onboarding-target="step"
         style="display:<%= @step == 2 ? 'flex' : 'none' %>; flex:1; flex-direction:column; align-items:center; justify-content:center; padding:32px 32px 0; text-align:center;">
      <div style="background:#FBF8F4; border:1px solid #EFE9E1; border-radius:20px; padding:20px 24px; width:100%; max-width:280px; margin-bottom:32px; box-shadow:0 4px 16px rgba(45,41,37,0.07);">
        <div style="display:flex; align-items:center; gap:12px; padding-bottom:12px; margin-bottom:12px; border-bottom:1.5px solid #2D2925;">
          <div style="width:22px; height:22px; border-radius:50%; border:2px dashed #C7BEB1; flex:none;"></div>
          <div style="height:10px; border-radius:6px; background:#EFE9E1; flex:1;"></div>
        </div>
        <% 3.times do %>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px;">
            <div style="width:22px; height:22px; border-radius:50%; border:2px solid #C7BEB1; flex:none;"></div>
            <div style="height:9px; border-radius:6px; background:#EFE9E1; flex:1;"></div>
          </div>
        <% end %>
      </div>
      <div style="font-size:12px; font-weight:800; letter-spacing:0.1em; color:#C2956F; text-transform:uppercase; margin-bottom:10px;">Shoulds</div>
      <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.15; margin-bottom:14px;">Put it down.<br>Stop carrying it.</div>
      <div style="font-size:15px; font-weight:600; color:#998F82; line-height:1.6; max-width:280px;">Every "I should" is a leak. The thought comes back. And again. Each time it costs you. Write it here once. It is safe, waiting for when you are ready to tackle it.</div>
    </div>

    <%# Step 3: Today %>
    <div data-onboarding-target="step"
         style="display:<%= @step == 3 ? 'flex' : 'none' %>; flex:1; flex-direction:column; align-items:center; justify-content:center; padding:32px 32px 0; text-align:center;">
      <div style="background:#FBF8F4; border:1px solid #EFE9E1; border-radius:20px; padding:20px 24px; width:100%; max-width:280px; margin-bottom:32px; box-shadow:0 4px 16px rgba(45,41,37,0.07);">
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
          <svg width="36" height="36" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="16" fill="none" stroke="#EFE9E1" stroke-width="4"/>
            <circle cx="18" cy="18" r="16" fill="none" stroke="#2D2925" stroke-width="4" stroke-dasharray="64 37" stroke-dashoffset="25" stroke-linecap="round"/>
            <text x="18" y="23" text-anchor="middle" font-family="Nunito,sans-serif" font-weight="800" font-size="10" fill="#2D2925">64%</text>
          </svg>
          <div>
            <div style="height:9px; border-radius:6px; background:#EFE9E1; width:100px; margin-bottom:5px;"></div>
            <div style="height:8px; border-radius:6px; background:#EFE9E1; width:70px;"></div>
          </div>
        </div>
        <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px;">
          <div style="width:22px; height:22px; border-radius:50%; background:#2D2925; display:flex; align-items:center; justify-content:center; flex:none;">
            <svg width="12" height="12" viewBox="0 0 12 12"><polyline points="2,6 5,9 10,3" fill="none" stroke="#FBF8F4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div style="height:9px; border-radius:6px; background:#EFE9E1; flex:1;"></div>
        </div>
        <% [2, 3].each do |n| %>
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:10px;">
            <div style="width:22px; height:22px; border-radius:50%; border:2px solid #C7BEB1; display:flex; align-items:center; justify-content:center; flex:none; font-size:10px; font-weight:800; color:#C7BEB1;"><%= n %></div>
            <div style="height:9px; border-radius:6px; background:#EFE9E1; flex:1;"></div>
          </div>
        <% end %>
      </div>
      <div style="font-size:12px; font-weight:800; letter-spacing:0.1em; color:#C2956F; text-transform:uppercase; margin-bottom:10px;">Today</div>
      <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.15; margin-bottom:14px;">Just today's handful</div>
      <div style="font-size:15px; font-weight:600; color:#998F82; line-height:1.6; max-width:280px;">A few clear priorities, not a hundred. Today is where you see them and give them your focus, one at a time.</div>
    </div>

    <%# Step 4: Planner %>
    <div data-onboarding-target="step"
         style="display:<%= @step == 4 ? 'flex' : 'none' %>; flex:1; flex-direction:column; align-items:center; justify-content:center; padding:32px 32px 0; text-align:center;">
      <div style="background:#FBF8F4; border:1px solid #EFE9E1; border-radius:20px; padding:20px 24px; width:100%; max-width:280px; margin-bottom:32px; box-shadow:0 4px 16px rgba(45,41,37,0.07);">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:14px;">
          <div style="height:9px; border-radius:6px; background:#EFE9E1; width:80px;"></div>
          <div style="display:flex; gap:6px;">
            <div style="width:12px; height:12px; border-radius:50%; background:#EFE9E1;"></div>
            <div style="width:12px; height:12px; border-radius:50%; background:#EFE9E1;"></div>
          </div>
        </div>
        <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:6px;">
          <% rings = [1.0, 0.5, 0.25, 0.75, 0.0, 0.1, 0.6, 1.0, 0.8, 0.0, 0.4, 0.9, 0.0, 0.3] %>
          <% rings.each do |fill| %>
            <svg width="24" height="24" viewBox="0 0 24 24" style="margin:0 auto;">
              <circle cx="12" cy="12" r="10" fill="<%= fill == 0.0 ? '#EFE9E1' : 'none' %>" stroke="<%= fill == 0.0 ? 'none' : '#EFE9E1' %>" stroke-width="4"/>
              <% if fill > 0 %>
                <% dash = (fill * 62.8).round(1) %>
                <circle cx="12" cy="12" r="10" fill="none" stroke="#2D2925" stroke-width="4"
                        stroke-dasharray="<%= dash %> <%= (62.8 - dash).round(1) %>"
                        stroke-dashoffset="15.7" stroke-linecap="round"/>
              <% end %>
            </svg>
          <% end %>
        </div>
      </div>
      <div style="font-size:12px; font-weight:800; letter-spacing:0.1em; color:#C2956F; text-transform:uppercase; margin-bottom:10px;">Planner</div>
      <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.15; margin-bottom:14px;">Set intentions.<br>Honour your days.</div>
      <div style="font-size:15px; font-weight:600; color:#998F82; line-height:1.6; max-width:280px;">Set intentions for tomorrow while your mind is calm, and look back on the days behind you. Each ring shows how far a day got.</div>
    </div>

    <%# Step 5: Gratitude %>
    <div data-onboarding-target="step"
         style="display:<%= @step == 5 ? 'flex' : 'none' %>; flex:1; flex-direction:column; align-items:center; justify-content:center; padding:32px 32px 0; text-align:center; overflow-y:auto;">
      <div style="width:120px; height:120px; border-radius:50%; background:#EDE8E1; display:flex; align-items:center; justify-content:center; margin-bottom:32px; position:relative;">
        <svg width="52" height="48" viewBox="0 0 52 48" fill="none">
          <path d="M26 44C26 44 4 30 4 16C4 9.4 9.4 4 16 4C19.8 4 23.2 5.8 26 8.8C28.8 5.8 32.2 4 36 4C42.6 4 48 9.4 48 16C48 30 26 44 26 44Z" fill="#C2956F"/>
        </svg>
        <div style="position:absolute; top:18px; right:18px; width:7px; height:7px; border-radius:50%; background:#2D2925;"></div>
        <div style="position:absolute; bottom:22px; left:16px; width:5px; height:5px; border-radius:50%; background:#2D2925;"></div>
        <div style="position:absolute; top:26px; left:12px; width:4px; height:4px; border-radius:50%; background:#C7BEB1;"></div>
      </div>
      <div style="font-size:12px; font-weight:800; letter-spacing:0.1em; color:#C2956F; text-transform:uppercase; margin-bottom:10px;">Gratitude</div>
      <div style="font-size:28px; font-weight:900; color:#2D2925; line-height:1.15; margin-bottom:14px;">Notice what already<br>went right</div>
      <div style="font-size:15px; font-weight:600; color:#998F82; line-height:1.6; max-width:280px; margin-bottom:20px;">As you plan, take a moment to name a few good things. A small habit with real effects:</div>
      <div style="text-align:left; max-width:280px; width:100%; margin-bottom:24px;">
        <% ["Lowers stress and anxiety", "Improves sleep and mood", "Trains your eye for the good"].each do |benefit| %>
          <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
            <svg width="16" height="16" viewBox="0 0 16 16"><polyline points="2,8 6,12 14,4" fill="none" stroke="#C2956F" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span style="font-size:14px; font-weight:700; color:#2D2925;"><%= benefit %></span>
          </div>
        <% end %>
      </div>
      <div style="background:#F4EFE8; border-radius:16px; padding:16px 20px; width:100%; max-width:280px; display:flex; align-items:center; justify-content:space-between; gap:12px;">
        <div>
          <div style="font-size:14px; font-weight:800; color:#2D2925; margin-bottom:2px;">Turn on the gratitude journal</div>
          <div style="font-size:12px; font-weight:600; color:#998F82;">You can change this anytime in Settings.</div>
        </div>
        <label style="position:relative; display:inline-flex; align-items:center; cursor:pointer; flex:none;">
          <input type="checkbox" data-onboarding-target="gratitudeToggle" checked
                 style="position:absolute; opacity:0; width:0; height:0;" class="onboarding-gratitude-input">
          <div class="onboarding-toggle"></div>
        </label>
      </div>
    </div>

  </div>

  <%# Navigation buttons %>
  <div style="padding:20px 24px 32px; display:flex; gap:12px; align-items:center; margin-top:auto; flex-shrink:0;">
    <button type="button" data-onboarding-target="backBtn" data-action="onboarding#back"
            style="width:52px; height:52px; border-radius:50%; border:1.5px solid #EFE9E1; background:#FBF8F4; cursor:pointer; display:<%= @step == 1 ? 'none' : 'flex' %>; align-items:center; justify-content:center; flex:none;">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="#2D2925" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="11,4 6,9 11,14"/>
      </svg>
    </button>
    <button type="button" data-onboarding-target="nextBtn" data-action="onboarding#next"
            style="flex:1; height:52px; border-radius:16px; background:#2D2925; color:#FBF8F4; border:none; font-size:16px; font-weight:800; font-family:inherit; cursor:pointer; display:<%= @step == 5 ? 'none' : '' %>;">
      Next
    </button>
    <button type="submit" data-onboarding-target="completeBtn" data-action="onboarding#submit"
            style="flex:1; height:52px; border-radius:16px; background:#2D2925; color:#FBF8F4; border:none; font-size:16px; font-weight:800; font-family:inherit; cursor:pointer; display:<%= @step != 5 ? 'none' : '' %>;">
      Get started
    </button>
  </div>
<% end %>
