<div style="flex:1; display:flex; flex-direction:column; padding:0 8px; min-height:0;">
  <div style="flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;">
    <img src="/icon.png" alt="Shoulds" style="width:84px; height:84px; border-radius:26px; box-shadow:0 16px 30px rgba(45,41,37,0.22);">
    <div style="font-size:36px; font-weight:900; color:#2D2925; margin-top:26px; line-height:1;">Shoulds</div>
    <div style="font-size:16px; font-weight:600; color:#8A8076; margin-top:12px; max-width:252px; line-height:1.5;">Dump what's on your mind. Plan the day that actually matters.</div>
  </div>
  <div style="flex:none; padding:0 24px 42px; display:flex; flex-direction:column; align-items:stretch; gap:16px;">
    <%= button_to "/auth/google_oauth2", method: :post, data: { turbo: false }, form: { style: "width:100%;" }, style: "display:flex; align-items:center; justify-content:center; gap:12px; width:100%; height:56px; border-radius:16px; border:1px solid #E4DDD2; background:#FFFFFF; cursor:pointer; box-shadow:0 1px 2px rgba(45,41,37,0.04), 0 8px 20px rgba(45,41,37,0.06); font-family:inherit;" do %>
      <svg width="20" height="20" viewBox="0 0 48 48"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path></svg>
      <span style="font-size:16px; font-weight:800; color:#2D2925;">Continue with Google</span>
    <% end %>
    <div style="font-size:12px; font-weight:600; color:#A39A8D; text-align:center; line-height:1.5; max-width:268px;">By continuing you agree to the Terms of Service and Privacy Policy.</div>
  </div>
</div>
